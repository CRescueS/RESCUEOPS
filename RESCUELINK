<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>RescueLink Supabase</title>
    <!-- Supabase JS Library -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --bg: #0b1220; --card: #121a2b; --text: #eef4ff; --red: #ff4d4d; --green: #00c853; }
        body { margin: 0; font-family: sans-serif; background: var(--bg); color: var(--text); padding: 15px; }
        .card { background: var(--card); padding: 15px; border-radius: 12px; margin-bottom: 10px; border: 1px solid #24314d; }
        .input { width: 100%; padding: 12px; margin: 5px 0; border-radius: 8px; border: 1px solid #24314d; background: #000; color: #fff; box-sizing: border-box; }
        .btn { border: 0; padding: 12px; border-radius: 8px; color: #fff; font-weight: bold; cursor: pointer; width: 100%; margin-top: 5px; }
        .btn-dispatch { background: var(--red); font-size: 16px; }
        .alert-btn { background: #444; margin-bottom: 10px; }
        .incident { border-left: 5px solid var(--red); margin-top: 10px; animation: slide 0.3s ease; }
        @keyframes slide { from { opacity: 0; transform: translateX(-10px); } }
    </style>
</head>
<body>

    <h3 style="color:var(--red)">🚨 RescueLink LIVE</h3>
    
    <button id="enableAudio" class="btn alert-btn">🔇 Tap to Enable Audio Alerts</button>

    <div class="card">
        <input id="loc" class="input" placeholder="Incident Location">
        <input id="unit" class="input" placeholder="Units (e.g. R1, P2)">
        <button class="btn btn-dispatch" onclick="sendToSupabase()">SEND LIVE DISPATCH</button>
    </div>

    <div id="feed"></div>

<script>
    // --- CONFIGURATION ---
   
import { createClient } from '@supabase/supabase-js'
const supabaseUrl = 'https://jcctioskmhikksydvqdh.supabase.co'
const supabaseKey = process.env.SUPABASE_KEY
const supabase = createClient(supabaseUrl, supabaseKey)

    let audioEnabled = false;

    // --- INITIAL LOAD ---
    async function loadHistory() {
        const { data } = await supabase.from('incidents').select('*').order('created_at', { ascending: false }).limit(10);
        data.forEach(item => displayIncident(item, false));
    }

    // --- REALTIME LISTENER ---
    supabase
        .channel('schema-db-changes')
        .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'incidents' }, payload => {
            playAlert();
            displayIncident(payload.new, true);
        })
        .subscribe();

    // --- FUNCTIONS ---
    async function sendToSupabase() {
        const loc = document.getElementById('loc').value;
        const unit = document.getElementById('unit').value;
        if (!loc) return alert("Location required");

        await supabase.from('incidents').insert([{ location: loc, units: unit, type: 'DISPATCH' }]);
        document.getElementById('loc').value = '';
    }

    function displayIncident(d, isNew) {
        const div = document.createElement('div');
        div.className = 'card incident';
        div.innerHTML = `<b>${d.type || 'INCIDENT'}</b><br>📍 ${d.location}<br>🚒 ${d.units}<br><small>${new Date(d.created_at).toLocaleTimeString()}</small>`;
        const feed = document.getElementById('feed');
        isNew ? feed.prepend(div) : feed.appendChild(div);
    }

    // --- AUDIO ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    document.getElementById('enableAudio').onclick = function() {
        audioEnabled = true;
        this.innerText = "🔊 Audio Alerts Active";
        this.style.background = "#2e7d32";
    };

    function playAlert() {
        if (!audioEnabled) return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'square';
        osc.frequency.setValueAtTime(900, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(300, audioCtx.currentTime + 0.6);
        gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.6);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start(); osc.stop(audioCtx.currentTime + 0.6);
        if (navigator.vibrate) navigator.vibrate([400, 200, 400]);
    }

    loadHistory();
</script>
</body>
</html>
